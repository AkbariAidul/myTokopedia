<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tokopedia" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#00AA5B</item>
        <item name="colorPrimaryVariant">#008A4A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF5722</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#00AA5B</item>
    </style>

    <!-- Splash Screen Theme with solid background -->
    <style name="Theme.Tokopedia.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/tokopedia_green</item>
        <item name="android:statusBarColor">@color/tokopedia_green</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Rounded Corner ImageView Style -->
    <style name="RoundedCornerImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <!-- Rounded Image Style with larger radius -->
    <style name="RoundedImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>
</resources>
